@model KryskataFund.Models.Fund
@{
    ViewData["Title"] = "Complete Donation";
    var amount = ViewBag.Amount ?? 0;
}

<div class="page-root">
    <div class="payment-container">
        <div class="payment-card">
            <!-- Payment Header -->
            <div class="payment-header">
                <a asp-action="Details" asp-route-id="@Model.Id" class="payment-back">
                    <span>←</span> Back
                </a>
                <h1 class="payment-title">Complete your donation</h1>
                <p class="payment-subtitle">Supporting: @Model.Title</p>
            </div>

            <!-- Amount Display -->
            <div class="payment-amount-box">
                <span class="payment-amount-label">Donation amount</span>
                <span class="payment-amount-value">€@amount</span>
            </div>

            <!-- Stripe Checkout Button -->
            <div class="payment-form">
                <p style="text-align: center; color: rgba(255,255,255,0.7); margin-bottom: 1.5rem;">
                    You will be redirected to Stripe's secure checkout page
                </p>

                <button type="button" class="btn-pay" id="payBtn">
                    <span class="btn-pay-text">Pay with Stripe — €@amount</span>
                    <div class="btn-pay-loader">
                        <div class="loader-spinner"></div>
                    </div>
                </button>
            </div>

            <!-- Security Note -->
            <div class="payment-security">
                <span class="security-icon"></span>
                <span>Secure payment powered by Stripe</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://js.stripe.com/v3/"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const payBtn = document.getElementById('payBtn');
            const fundId = @Model.Id;
            const amount = @amount;

            payBtn.addEventListener('click', async function() {
                payBtn.disabled = true;
                payBtn.classList.add('loading');

                try {
                    const response = await fetch('/Funds/CreateCheckoutSession', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: `fundId=${fundId}&amount=${amount}`
                    });
                    const data = await response.json();
                    if (data.success) {
                        window.location.href = data.sessionUrl;
                    } else {
                        alert(data.message || 'Error creating checkout session');
                        payBtn.disabled = false;
                        payBtn.classList.remove('loading');
                    }
                } catch (error) {
                    alert('An error occurred');
                    payBtn.disabled = false;
                    payBtn.classList.remove('loading');
                }
            });
        });
    </script>
}
