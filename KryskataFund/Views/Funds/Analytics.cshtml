@model KryskataFund.Models.Fund
@{
    ViewData["Title"] = "Analytics - " + Model.Title;
    var donations = ViewBag.Donations as List<KryskataFund.Models.Donation> ?? new List<KryskataFund.Models.Donation>();
    var dailyTotals = ViewBag.DailyTotals as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var topDonors = ViewBag.TopDonors as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var uniqueDonors = (int)(ViewBag.UniqueDonors ?? 0);
    var totalSupporters = Model.SupportersCount;
    var totalRaised = Model.RaisedAmount;
    var avgDonation = donations.Count > 0 ? totalRaised / donations.Count : 0m;
    var dailyList = dailyTotals.ToList();
    var maxDaily = dailyList.Any() ? dailyList.Max(d => (decimal)d.Amount) : 1m;
    if (maxDaily == 0) { maxDaily = 1m; }
}

<div style="min-height: 100vh; padding: 32px 0;">
    <div style="max-width: 1100px; margin: 0 auto; padding: 0 24px;">

        <!-- Header -->
        <div style="margin-bottom: 36px;">
            <a asp-controller="Funds" asp-action="Details" asp-route-id="@Model.Id"
               style="color: #6d6f8c; text-decoration: none; font-size: 14px; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 16px; transition: color 0.2s;"
               onmouseover="this.style.color='#46e6a4'" onmouseout="this.style.color='#6d6f8c'">
                <span style="font-size: 18px;">&#8592;</span>
                Back to campaign
            </a>
            <h1 style="color: #f7f7ff; font-size: 28px; font-weight: 700; margin: 0 0 6px 0;">@Model.Title</h1>
            <p style="color: #6d6f8c; font-size: 15px; margin: 0;">Campaign Analytics</p>
        </div>

        <!-- Overview Stats Row -->
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 36px;">
            <!-- Total Raised -->
            <div style="background: rgba(255,255,255,0.03); border: 1px solid #222437; border-radius: 16px; padding: 24px;">
                <div style="color: #6d6f8c; font-size: 13px; font-weight: 500; margin-bottom: 8px;">Total Raised</div>
                <div style="color: #46e6a4; font-size: 28px; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@("\u20AC")@totalRaised.ToString("N0")</div>
            </div>
            <!-- Total Supporters -->
            <div style="background: rgba(255,255,255,0.03); border: 1px solid #222437; border-radius: 16px; padding: 24px;">
                <div style="color: #6d6f8c; font-size: 13px; font-weight: 500; margin-bottom: 8px;">Total Supporters</div>
                <div style="color: #f7f7ff; font-size: 28px; font-weight: 700;">@totalSupporters</div>
            </div>
            <!-- Unique Donors -->
            <div style="background: rgba(255,255,255,0.03); border: 1px solid #222437; border-radius: 16px; padding: 24px;">
                <div style="color: #6d6f8c; font-size: 13px; font-weight: 500; margin-bottom: 8px;">Unique Donors</div>
                <div style="color: #f7f7ff; font-size: 28px; font-weight: 700;">@uniqueDonors</div>
            </div>
            <!-- Average Donation -->
            <div style="background: rgba(255,255,255,0.03); border: 1px solid #222437; border-radius: 16px; padding: 24px;">
                <div style="color: #6d6f8c; font-size: 13px; font-weight: 500; margin-bottom: 8px;">Average Donation</div>
                <div style="color: #f7f7ff; font-size: 28px; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@("\u20AC")@avgDonation.ToString("N2")</div>
            </div>
        </div>

        <!-- Donations Over Time Chart -->
        <div style="background: #0f1017; border: 1px solid #222437; border-radius: 16px; padding: 28px; margin-bottom: 36px;">
            <h2 style="color: #f7f7ff; font-size: 18px; font-weight: 600; margin: 0 0 24px 0;">Donations Over Time</h2>
            @if (dailyList.Any())
            {
                <div style="display: flex; align-items: flex-end; gap: 6px; height: 200px; padding-bottom: 32px; position: relative;">
                    @foreach (var day in dailyList)
                    {
                        var pct = (decimal)day.Amount / maxDaily * 100;
                        var barHeight = Math.Max(pct, 2);
                        <div style="flex: 1; display: flex; flex-direction: column; align-items: center; position: relative; height: 100%;">
                            <div style="flex: 1; width: 100%; display: flex; align-items: flex-end;">
                                <div class="analytics-bar"
                                     style="width: 100%; height: @barHeight%; min-height: 3px; background: linear-gradient(to top, #46e6a4, #22d3ee); border-radius: 6px 6px 2px 2px; position: relative; cursor: pointer; transition: opacity 0.2s;"
                                     title="@("\u20AC")@(((decimal)day.Amount).ToString("N2"))"
                                     onmouseover="this.style.opacity='0.8'; this.querySelector('.bar-tooltip').style.display='block';"
                                     onmouseout="this.style.opacity='1'; this.querySelector('.bar-tooltip').style.display='none';">
                                    <div class="bar-tooltip" style="display: none; position: absolute; top: -32px; left: 50%; transform: translateX(-50%); background: #1a1b2e; color: #f7f7ff; font-size: 12px; padding: 4px 10px; border-radius: 6px; white-space: nowrap; border: 1px solid #222437; z-index: 10;">
                                        @("\u20AC")@(((decimal)day.Amount).ToString("N2"))
                                    </div>
                                </div>
                            </div>
                            <div style="color: #6d6f8c; font-size: 11px; margin-top: 8px; white-space: nowrap; position: absolute; bottom: -28px;">@day.Date</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="color: #6d6f8c; text-align: center; padding: 48px 0; font-size: 14px;">No donation data available yet.</div>
            }
        </div>

        <!-- Two-column layout: Top Donors + Recent Donations -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 36px;">

            <!-- Top Donors Table -->
            <div style="background: #0f1017; border: 1px solid #222437; border-radius: 16px; padding: 28px;">
                <h2 style="color: #f7f7ff; font-size: 18px; font-weight: 600; margin: 0 0 20px 0;">Top Donors</h2>
                @{ var topDonorList = topDonors.Take(10).ToList(); }
                @if (topDonorList.Any())
                {
                    <table style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr>
                                <th style="text-align: left; color: #6d6f8c; font-size: 12px; font-weight: 500; padding: 0 0 12px 0; border-bottom: 1px solid #222437;">#</th>
                                <th style="text-align: left; color: #6d6f8c; font-size: 12px; font-weight: 500; padding: 0 0 12px 0; border-bottom: 1px solid #222437;">Donor</th>
                                <th style="text-align: right; color: #6d6f8c; font-size: 12px; font-weight: 500; padding: 0 0 12px 0; border-bottom: 1px solid #222437;">Total</th>
                                <th style="text-align: right; color: #6d6f8c; font-size: 12px; font-weight: 500; padding: 0 0 12px 0; border-bottom: 1px solid #222437;">Count</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < topDonorList.Count; i++)
                            {
                                var donor = topDonorList[i];
                                var rankColor = i == 0 ? "#FFD700" : i == 1 ? "#C0C0C0" : i == 2 ? "#CD7F32" : "#6d6f8c";
                                <tr>
                                    <td style="padding: 12px 0; color: @rankColor; font-size: 14px; font-weight: 600; border-bottom: 1px solid rgba(34,36,55,0.5);">@(i + 1)</td>
                                    <td style="padding: 12px 0; color: #f7f7ff; font-size: 14px; border-bottom: 1px solid rgba(34,36,55,0.5);">@donor.DonorName</td>
                                    <td style="padding: 12px 0; color: #46e6a4; font-size: 14px; font-weight: 600; text-align: right; border-bottom: 1px solid rgba(34,36,55,0.5);">@("\u20AC")@(((decimal)donor.TotalAmount).ToString("N2"))</td>
                                    <td style="padding: 12px 0; color: #6d6f8c; font-size: 14px; text-align: right; border-bottom: 1px solid rgba(34,36,55,0.5);">@donor.DonationCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div style="color: #6d6f8c; text-align: center; padding: 32px 0; font-size: 14px;">No donors yet.</div>
                }
            </div>

            <!-- Recent Donations List -->
            <div style="background: #0f1017; border: 1px solid #222437; border-radius: 16px; padding: 28px;">
                <h2 style="color: #f7f7ff; font-size: 18px; font-weight: 600; margin: 0 0 20px 0;">Recent Donations</h2>
                @{ var recentDonations = donations.Take(20).ToList(); }
                @if (recentDonations.Any())
                {
                    <div style="display: flex; flex-direction: column; gap: 0;">
                        @foreach (var donation in recentDonations)
                        {
                            <div style="display: flex; align-items: center; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid rgba(34,36,55,0.5);">
                                <div>
                                    <div style="color: #f7f7ff; font-size: 14px; font-weight: 500;">@donation.DonorName</div>
                                    <div style="color: #6d6f8c; font-size: 12px; margin-top: 2px;">@donation.CreatedAt.ToString("MMM d, yyyy")</div>
                                </div>
                                <div style="color: #46e6a4; font-size: 15px; font-weight: 600;">@("\u20AC")@donation.Amount.ToString("N2")</div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="color: #6d6f8c; text-align: center; padding: 32px 0; font-size: 14px;">No donations yet.</div>
                }
            </div>
        </div>

        <!-- Export Button -->
        <div style="text-align: center; margin-bottom: 48px;">
            <a href="/Funds/ExportDonors/@Model.Id"
               style="display: inline-flex; align-items: center; gap: 8px; background: rgba(70,230,164,0.1); color: #46e6a4; border: 1px solid rgba(70,230,164,0.3); border-radius: 12px; padding: 14px 32px; font-size: 15px; font-weight: 600; text-decoration: none; transition: all 0.2s;"
               onmouseover="this.style.background='rgba(70,230,164,0.2)'; this.style.borderColor='rgba(70,230,164,0.5)';"
               onmouseout="this.style.background='rgba(70,230,164,0.1)'; this.style.borderColor='rgba(70,230,164,0.3)';">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                    <polyline points="7 10 12 15 17 10"/>
                    <line x1="12" y1="15" x2="12" y2="3"/>
                </svg>
                Export Donors CSV
            </a>
        </div>

    </div>
</div>

<style>
    @@media (max-width: 768px) {
        div[style*="grid-template-columns: repeat(4"] {
            grid-template-columns: repeat(2, 1fr) !important;
        }
        div[style*="grid-template-columns: 1fr 1fr"] {
            grid-template-columns: 1fr !important;
        }
    }
</style>
