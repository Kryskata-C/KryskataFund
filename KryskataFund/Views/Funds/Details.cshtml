@model KryskataFund.Models.Fund
@functions {
    string GetTimeAgo(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime;
        if (timeSpan.TotalMinutes < 1) return "just now";
        if (timeSpan.TotalMinutes < 60) return $"{(int)timeSpan.TotalMinutes} min ago";
        if (timeSpan.TotalHours < 24) return $"{(int)timeSpan.TotalHours} hours ago";
        if (timeSpan.TotalDays < 7) return $"{(int)timeSpan.TotalDays} days ago";
        return dateTime.ToString("MMM d");
    }
}
@{
    ViewData["Title"] = Model.Title;
    var progressPercent = Model.ProgressPercent;
    var isOverfunded = Model.RaisedAmount > Model.GoalAmount;
    var statusText = isOverfunded ? $"{progressPercent}% funded" : Model.DaysLeft == 0 ? "Ended" : $"{Model.DaysLeft} days left";
    var isSignedIn = ViewBag.IsSignedIn ?? false;
    var isCreator = ViewBag.IsCreator ?? false;
    var fundUpdates = ViewBag.FundUpdates as List<KryskataFund.Models.FundUpdate> ?? new List<KryskataFund.Models.FundUpdate>();
    var milestones = ViewBag.Milestones as List<KryskataFund.Models.FundMilestone> ?? new List<KryskataFund.Models.FundMilestone>();
    var signInUrl = Url.Action("SignIn", "Account", new { returnUrl = Context.Request.Path });
    var recurringCount = (int)(ViewBag.RecurringCount ?? 0);
    var hasRecurring = (bool)(ViewBag.HasRecurring ?? false);
    var recurringAmount = (decimal)(ViewBag.RecurringAmount ?? 0m);
    var isOriginalCreator = (bool)(ViewBag.IsOriginalCreator ?? false);
    var collaborators = ViewBag.Collaborators as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var deadlineExtension = ViewBag.DeadlineExtension as KryskataFund.Models.DeadlineExtension;
    var canExtend = (bool)isCreator && deadlineExtension == null && (Model.EndDate - DateTime.UtcNow).TotalDays <= 7 && (Model.EndDate - DateTime.UtcNow).TotalDays >= -7;
}

<div class="page-root">
    <div class="page-shell">
        <!-- Back button -->
        <a asp-controller="Home" asp-action="Index" class="back-link">
            <span class="back-arrow">←</span>
            Back to campaigns
        </a>

        <div class="fund-detail-grid">
            <!-- Main content -->
            <section class="fund-detail-main">
                <!-- Hero image area -->
                <div class="fund-detail-hero" style="@(Model.ImageUrl != null ? $"background: url('{Model.ImageUrl}') center/cover;" : "")">
                    <div class="fund-detail-hero-gradient"></div>
                    <div class="fund-detail-category-tag" style="--cat-color: @Model.CategoryColor;">
                        <span class="fund-detail-tag-dot" style="background: @Model.CategoryColor; box-shadow: 0 0 10px @Model.CategoryColor;"></span>
                        @Model.Category
                    </div>
                    @if (isOverfunded)
                    {
                        <div class="fund-detail-badge fund-detail-badge--success">
                            Goal reached!
                        </div>
                    }
                    @if (Model.DaysLeft == 0 && !isOverfunded)
                    {
                        <div class="fund-detail-badge fund-detail-badge--ended">
                            Campaign Ended
                        </div>
                    }
                </div>

                <!-- Title and story -->
                <div class="fund-detail-content">
                    <h1 class="fund-detail-title">@Model.Title</h1>

                    <div class="fund-detail-creator">
                        <div class="fund-detail-avatar" style="background: linear-gradient(135deg, @Model.CategoryColor, #4da8ff);"></div>
                        <span>Created by <strong>@Model.CreatorName</strong></span>
                    </div>

                    @if (collaborators.Any())
                    {
                        <div class="fund-collaborators">
                            <span class="collaborators-label">Team:</span>
                            <div class="collaborators-list">
                                @foreach (var collab in collaborators)
                                {
                                    <div class="collaborator-chip">
                                        <div class="collaborator-avatar"></div>
                                        <span>@@@collab.Email.Split("@@")[0]</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @if (isOriginalCreator)
                    {
                        <button class="btn-manage-team" id="openTeamModal">
                            <span>👥</span> Manage Team
                        </button>
                    }

                    <div class="fund-detail-story">
                        <h2>About this campaign</h2>
                        <p>@Model.Description</p>
                    </div>

                    <!-- Updates section -->
                    <div class="fund-detail-updates">
                        <div class="updates-header">
                            <h2>Updates <span class="updates-count">(@fundUpdates.Count)</span></h2>
                            @if (isCreator)
                            {
                                <button class="btn-post-update" id="openUpdateModal">
                                    <span>+</span> Post Update
                                </button>
                            }
                        </div>

                        <div class="updates-list" id="updatesList">
                            @if (fundUpdates.Count == 0)
                            {
                                <div class="fund-detail-update-empty" id="emptyUpdates">
                                    <span></span>
                                    <p>No updates yet</p>
                                    @if (isCreator)
                                    {
                                        <small>Share progress with your supporters!</small>
                                    }
                                    else
                                    {
                                        <small>The creator hasn't posted any updates.</small>
                                    }
                                </div>
                            }
                            else
                            {
                                @foreach (var update in fundUpdates)
                                {
                                    <div class="update-item">
                                        <div class="update-header">
                                            <h3 class="update-title">@update.Title</h3>
                                            <span class="update-date">@update.CreatedAt.ToString("MMM d, yyyy")</span>
                                        </div>
                                        <p class="update-content">@update.Content</p>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <!-- Milestones section -->
                    <div class="fund-detail-milestones">
                        <div class="milestones-header">
                            <h2>Milestones <span class="milestones-count">(@milestones.Count)</span></h2>
                            @if (isCreator)
                            {
                                <button class="btn-post-update" id="openMilestoneModal">
                                    <span>+</span> Add Milestone
                                </button>
                            }
                        </div>

                        <div class="milestones-list" id="milestonesList">
                            @if (milestones.Count == 0)
                            {
                                <div class="fund-detail-update-empty" id="emptyMilestones">
                                    <span></span>
                                    <p>No milestones yet</p>
                                    @if (isCreator)
                                    {
                                        <small>Set sub-goals to show your supporters what you'll achieve!</small>
                                    }
                                    else
                                    {
                                        <small>The creator hasn't set any milestones.</small>
                                    }
                                </div>
                            }
                            else
                            {
                                @foreach (var milestone in milestones)
                                {
                                    var milestoneProgress = Model.GoalAmount > 0
                                        ? (int)Math.Min(100, Math.Round(Model.RaisedAmount / milestone.TargetAmount * 100))
                                        : 0;
                                    <div class="milestone-item @(milestone.IsReached ? "milestone-reached" : "")" data-milestone-id="@milestone.Id">
                                        <div class="milestone-header">
                                            <div class="milestone-title-row">
                                                <h3 class="milestone-title">@milestone.Title</h3>
                                                @if (milestone.IsReached)
                                                {
                                                    <span class="milestone-badge">Reached!</span>
                                                }
                                            </div>
                                            <div class="milestone-amount">€@milestone.TargetAmount.ToString("N0")</div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(milestone.Description))
                                        {
                                            <p class="milestone-description">@milestone.Description</p>
                                        }
                                        <div class="milestone-progress-bar">
                                            <div class="milestone-progress-fill" style="--milestone-progress: @Math.Min(100, milestoneProgress)%;"></div>
                                        </div>
                                        <div class="milestone-footer">
                                            <span class="milestone-percent">@milestoneProgress% of milestone</span>
                                            @if (isCreator)
                                            {
                                                <button class="milestone-delete-btn" data-milestone-id="@milestone.Id" title="Delete milestone">×</button>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    <!-- Comments section -->
                    <div class="fund-detail-comments" id="commentsSection">
                        <div class="comments-header">
                            <h2>Comments <span class="comments-count" id="commentsCount">(0)</span></h2>
                        </div>

                        @if (isSignedIn)
                        {
                            <div class="comment-form">
                                <div class="comment-form-row">
                                    <textarea id="commentInput" class="comment-input" placeholder="Leave a comment..." rows="2" maxlength="1000"></textarea>
                                </div>
                                <div class="comment-form-actions">
                                    <span class="comment-char-count" id="commentCharCount">0/1000</span>
                                    <button class="btn-post-comment" id="submitComment" disabled>Post Comment</button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="comment-signin-prompt">
                                <a href="@signInUrl">Sign in</a> to leave a comment.
                            </div>
                        }

                        <div class="comments-list" id="commentsList">
                            <div class="comments-empty" id="emptyComments">
                                <p>No comments yet. Be the first to share your thoughts!</p>
                            </div>
                        </div>
                    </div>

                    <!-- Add Milestone Modal (for creator only) -->
                    @if (isCreator)
                    {
                        <div class="update-modal" id="milestoneModal">
                            <div class="update-modal-backdrop" id="milestoneModalBackdrop"></div>
                            <div class="update-modal-content">
                                <div class="update-modal-header">
                                    <h3>Add a Milestone</h3>
                                    <button class="update-modal-close" id="closeMilestoneModal">×</button>
                                </div>
                                <div class="update-modal-body">
                                    <div class="update-form-group">
                                        <label for="milestoneTitle">Title</label>
                                        <input type="text" id="milestoneTitle" placeholder="e.g., Buy supplies" maxlength="200">
                                    </div>
                                    <div class="update-form-group">
                                        <label for="milestoneAmount">Target Amount (€)</label>
                                        <input type="number" id="milestoneAmount" placeholder="e.g., 500" min="1" step="1">
                                    </div>
                                    <div class="update-form-group">
                                        <label for="milestoneDescription">Description (optional)</label>
                                        <textarea id="milestoneDescription" rows="3" placeholder="What will you do when this milestone is reached?"></textarea>
                                    </div>
                                </div>
                                <div class="update-modal-footer">
                                    <button class="btn-update-cancel" id="cancelMilestone">Cancel</button>
                                    <button class="btn-update-submit" id="submitMilestone">Add Milestone</button>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Post Update Modal (for creator only) -->
                    @if (isCreator)
                    {
                        <div class="update-modal" id="updateModal">
                            <div class="update-modal-backdrop" id="updateModalBackdrop"></div>
                            <div class="update-modal-content">
                                <div class="update-modal-header">
                                    <h3>Post an Update</h3>
                                    <button class="update-modal-close" id="closeUpdateModal">×</button>
                                </div>
                                <div class="update-modal-body">
                                    <div class="update-form-group">
                                        <label for="updateTitle">Title</label>
                                        <input type="text" id="updateTitle" placeholder="What's new?" maxlength="200">
                                    </div>
                                    <div class="update-form-group">
                                        <label for="updateContent">Content</label>
                                        <textarea id="updateContent" rows="5" placeholder="Share your progress, milestones, or news with your supporters..."></textarea>
                                    </div>
                                </div>
                                <div class="update-modal-footer">
                                    <button class="btn-update-cancel" id="cancelUpdate">Cancel</button>
                                    <button class="btn-update-submit" id="submitUpdate">Post Update</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                    <!-- Extend Deadline Modal (for creator only) -->
                    @if (canExtend)
                    {
                        <div class="update-modal" id="extensionModal">
                            <div class="update-modal-backdrop" id="extensionModalBackdrop"></div>
                            <div class="update-modal-content">
                                <div class="update-modal-header">
                                    <h3>Extend Deadline</h3>
                                    <button class="update-modal-close" id="closeExtensionModal">&times;</button>
                                </div>
                                <div class="update-modal-body">
                                    <div class="update-form-group">
                                        <label for="extensionDaysSlider">Extension days</label>
                                        <div class="extension-slider-group">
                                            <input type="range" id="extensionDaysSlider" min="1" max="30" value="7" class="extension-slider">
                                            <div class="extension-days-display">
                                                <input type="number" id="extensionDaysInput" min="1" max="30" value="7" class="extension-days-input">
                                                <span class="extension-days-label">days</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="update-form-group">
                                        <label for="extensionReason">Reason for extension</label>
                                        <textarea id="extensionReason" rows="3" placeholder="Why do you need more time?" maxlength="500"></textarea>
                                        <small class="extension-char-count"><span id="extensionCharCount">0</span>/500</small>
                                    </div>
                                </div>
                                <div class="update-modal-footer">
                                    <button class="btn-update-cancel" id="cancelExtension">Cancel</button>
                                    <button class="btn-update-submit" id="submitExtension">Extend Deadline</button>
                                </div>
                            </div>
                        </div>
                    }
            </section>

            <!-- Sidebar with donation -->
            <aside class="fund-detail-sidebar">
                <div class="fund-detail-card">
                    <!-- Progress section -->
                    <div class="fund-detail-progress-section">
                        <div class="fund-detail-amount">
                            <span class="fund-detail-raised">€@Model.RaisedAmount.ToString("N0")</span>
                            <span class="fund-detail-goal">raised of €@Model.GoalAmount.ToString("N0") goal</span>
                        </div>

                        <div class="fund-detail-progress-bar">
                            <div class="fund-detail-progress-fill" style="--progress: @Math.Min(100, progressPercent)%;"></div>
                        </div>

                        <div class="fund-detail-stats">
                            <div class="fund-detail-stat">
                                <span class="fund-detail-stat-value">@Model.SupportersCount</span>
                                <span class="fund-detail-stat-label">supporters</span>
                            </div>
                            <div class="fund-detail-stat">
                                <span class="fund-detail-stat-value">@progressPercent%</span>
                                <span class="fund-detail-stat-label">funded</span>
                            </div>
                            <div class="fund-detail-stat">
                                <span class="fund-detail-stat-value">@(Model.DaysLeft == 0 ? "Ended" : Model.DaysLeft.ToString())</span>
                                <span class="fund-detail-stat-label">@(Model.DaysLeft == 0 ? "" : "days left")</span>
                            </div>
                            @if (recurringCount > 0)
                            {
                                <div class="fund-detail-stat">
                                    <span class="fund-detail-stat-value">@recurringCount</span>
                                    <span class="fund-detail-stat-label">monthly</span>
                                </div>
                            }
                        </div>

                        @if (deadlineExtension != null)
                        {
                            <div class="extension-badge">
                                <span class="extension-badge-icon">+@deadlineExtension.ExtensionDays</span>
                                <span class="extension-badge-text">Extended by @deadlineExtension.ExtensionDays days</span>
                            </div>
                        }
                    </div>

                    @if (canExtend)
                    {
                        <div class="extension-section">
                            <button class="btn-extend-deadline" id="openExtensionModal">
                                <span>+</span> Extend Deadline
                            </button>
                        </div>
                    }

                    <!-- Donation buttons -->
                    <div class="fund-detail-donate-section">
                        @if (Model.DaysLeft == 0)
                        {
                            <div class="campaign-ended-notice">
                                <div class="campaign-ended-icon">⏱</div>
                                <p class="campaign-ended-text">This campaign has ended</p>
                                <p class="campaign-ended-date">Ended on @Model.EndDate.ToString("MMMM d, yyyy")</p>
                            </div>
                            <button class="btn-donate btn-donate--disabled" disabled>
                                <span>Campaign Ended</span>
                            </button>
                        }
                        else
                        {
                            <div class="fund-detail-quick-amounts">
                                <button class="btn-quick-amount" data-amount="10">€10</button>
                                <button class="btn-quick-amount" data-amount="25">€25</button>
                                <button class="btn-quick-amount" data-amount="50">€50</button>
                                <button class="btn-quick-amount" data-amount="100">€100</button>
                                <div class="btn-custom-amount">
                                    <span class="custom-amount-label">€</span>
                                    <input type="number" class="custom-amount-input" placeholder="Custom" min="1" id="customAmount">
                                </div>
                            </div>

                            <div class="selected-amount-display" id="selectedAmountDisplay">
                                <span class="selected-amount-label">Your donation</span>
                                <span class="selected-amount-value">€<span id="animatedAmount">0</span></span>
                            </div>

                            @if (hasRecurring)
                            {
                                <div class="recurring-active-badge">
                                    <span class="recurring-icon">🔄</span>
                                    <div class="recurring-active-info">
                                        <span class="recurring-active-label">Monthly donation active</span>
                                        <span class="recurring-active-amount">€@recurringAmount.ToString("N0")/month</span>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="monthly-toggle" id="monthlyToggle">
                                    <label class="toggle-switch">
                                        <input type="checkbox" id="monthlyCheckbox">
                                        <span class="toggle-slider"></span>
                                    </label>
                                    <span class="monthly-toggle-label">Make it monthly</span>
                                </div>
                            }

                            <button class="btn-donate btn-donate--primary" id="donateBtn">
                                <span class="btn-donate-icon"></span>
                                <span id="donateBtnText">Donate now</span>
                            </button>
                        }

                        <button class="btn-donate btn-donate--ghost" id="shareBtn" onclick="document.getElementById('shareModal').style.display='flex'">
                            <span class="btn-donate-icon"></span>
                            Share campaign
                        </button>

                        <!-- Share Modal -->
                        <div id="shareModal" style="display:none;position:fixed;top:0;left:0;width:100%;height:100%;z-index:9999;align-items:center;justify-content:center;background:rgba(0,0,0,0.7);" onclick="if(event.target===this)this.style.display='none'">
                            <div class="share-modal">
                                <div class="share-modal-header">
                                    <h3 class="share-modal-title">Share campaign</h3>
                                    <button class="share-modal-close" onclick="document.getElementById('shareModal').style.display='none'">&times;</button>
                                </div>

                                <div class="share-modal-section">
                                    <label class="share-modal-label">Copy link</label>
                                    <div class="share-modal-link-row">
                                        <input type="text" class="share-modal-link-input" id="shareLinkInput" readonly value="@Context.Request.Scheme://@Context.Request.Host/Funds/Details/@Model.Id" />
                                        <button class="share-modal-copy-btn" id="shareCopyBtn" onclick="copyShareLink()">Copy</button>
                                    </div>
                                </div>

                                @if (isSignedIn)
                                {
                                    <div class="share-modal-section" id="shareContactsSection">
                                        <label class="share-modal-label">Share with contacts</label>
                                        <div id="shareContactsList" class="share-contacts-list">
                                            <div class="share-contacts-loading">Loading contacts...</div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (isSignedIn && !isCreator)
                        {
                            <a asp-controller="Messages" asp-action="Conversation" asp-route-userId="@Model.CreatorId" class="btn-donate btn-donate--ghost">
                                Message Creator
                            </a>
                        }
                    </div>

                    <!-- Recent supporters -->
                    <div class="fund-detail-supporters">
                        <h3>Recent supporters</h3>
                        <div class="fund-detail-supporter-list" id="supportersList">
                            @{
                                var donations = ViewBag.RecentDonations as List<KryskataFund.Models.Donation> ?? new List<KryskataFund.Models.Donation>();
                                var colors = new[] {
                                    "linear-gradient(135deg, #22c55e, #4ade80)",
                                    "linear-gradient(135deg, #4f46e5, #22d3ee)",
                                    "linear-gradient(135deg, #f97316, #fb7185)",
                                    "linear-gradient(135deg, #a855f7, #ec4899)",
                                    "linear-gradient(135deg, #facc15, #fb923c)"
                                };
                                var initialShow = 3;
                            }
                            @if (donations.Count == 0)
                            {
                                <div class="fund-detail-no-supporters" style="text-align: center; padding: 20px; color: var(--text-muted);">
                                    <p style="font-size: 13px;">No supporters yet. Be the first!</p>
                                </div>
                            }
                            else
                            {
                                var index = 0;
                                @foreach (var donation in donations)
                                {
                                    var colorIndex = Math.Abs(donation.DonorName.GetHashCode()) % colors.Length;
                                    var timeAgo = GetTimeAgo(donation.CreatedAt);
                                    var isHidden = index >= initialShow;
                                    <div class="fund-detail-supporter @(isHidden ? "supporter-hidden" : "")" data-index="@index" data-donation-id="@donation.Id" data-donation-amount="@donation.Amount" style="@(isHidden ? "display: none;" : "")">
                                        <div class="fund-detail-supporter-avatar" style="background: @colors[colorIndex];"></div>
                                        <div class="fund-detail-supporter-info">
                                            <span class="fund-detail-supporter-name">@donation.DonorName</span>
                                            <span class="fund-detail-supporter-amount">€@donation.Amount.ToString("N0")</span>
                                        </div>
                                        <span class="fund-detail-supporter-time">@timeAgo</span>
                                        @if (isCreator)
                                        {
                                            <button class="btn-refund-supporter" onclick="refundDonation(@donation.Id, this)" title="Refund this donation">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                                                    <polyline points="1 4 1 10 7 10"></polyline>
                                                    <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
                                                </svg>
                                            </button>
                                        }
                                    </div>
                                    index++;
                                }
                            }
                        </div>
                        @if (Model.SupportersCount > 3)
                        {
                            <div class="supporters-expand-section">
                                <button type="button" class="fund-detail-see-all" id="toggleSupportersBtn" data-expanded="false">
                                    <span id="toggleText">See all @Model.SupportersCount supporters</span>
                                    <span class="toggle-arrow" id="toggleArrow">↓</span>
                                </button>
                                <div class="supporters-pagination" id="supportersPagination" style="display: none;">
                                    <button type="button" class="pagination-btn" id="prevPageBtn" disabled>←</button>
                                    <span class="pagination-info" id="paginationInfo">Page 1</span>
                                    <button type="button" class="pagination-btn" id="nextPageBtn">→</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </aside>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const quickAmountBtns = document.querySelectorAll('.btn-quick-amount');
            const customAmountInput = document.getElementById('customAmount');
            const selectedAmountDisplay = document.getElementById('selectedAmountDisplay');
            const animatedAmountSpan = document.getElementById('animatedAmount');
            const donateBtn = document.getElementById('donateBtn');

            let currentAmount = 0;
            let displayedAmount = 0;
            let animationId = null;

            // Count up animation function
            function animateCountUp(targetAmount, duration = 600) {
                // Cancel any running animation
                if (animationId) {
                    cancelAnimationFrame(animationId);
                    animationId = null;
                }

                const startAmount = displayedAmount;
                const startTime = performance.now();

                // Show the display with animation
                selectedAmountDisplay.classList.add('visible');

                function updateCount(currentTime) {
                    const elapsed = currentTime - startTime;
                    const progress = Math.min(elapsed / duration, 1);

                    // Easing function (ease out cubic)
                    const easeProgress = 1 - Math.pow(1 - progress, 3);

                    displayedAmount = Math.round(startAmount + (targetAmount - startAmount) * easeProgress);
                    animatedAmountSpan.textContent = Math.max(0, displayedAmount);

                    if (progress < 1) {
                        animationId = requestAnimationFrame(updateCount);
                    } else {
                        displayedAmount = targetAmount;
                        animatedAmountSpan.textContent = targetAmount;
                        animationId = null;
                    }
                }

                animationId = requestAnimationFrame(updateCount);
            }

            // Handle quick amount button clicks
            quickAmountBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    // Remove active class from all buttons
                    quickAmountBtns.forEach(b => b.classList.remove('active'));
                    customAmountInput.classList.remove('active');
                    customAmountInput.value = '';

                    // Add active class to clicked button
                    this.classList.add('active');

                    const amount = parseInt(this.dataset.amount);
                    currentAmount = amount;
                    animateCountUp(amount);
                });
            });

            // Handle custom amount input
            customAmountInput.addEventListener('input', function() {
                quickAmountBtns.forEach(b => b.classList.remove('active'));

                const amount = parseInt(this.value) || 0;
                if (amount > 0) {
                    this.classList.add('active');
                    currentAmount = amount;
                    animateCountUp(amount);
                } else {
                    this.classList.remove('active');
                    selectedAmountDisplay.classList.remove('visible');
                }
            });

            customAmountInput.addEventListener('focus', function() {
                quickAmountBtns.forEach(b => b.classList.remove('active'));
            });

            // Handle donate button click
            const fundId = @Model.Id;

            donateBtn.addEventListener('click', function() {
                if (currentAmount > 0) {
                    // Redirect to payment page
                    window.location.href = '/Funds/Donate?id=' + fundId + '&amount=' + currentAmount;
                } else {
                    // Shake animation if no amount selected
                    selectedAmountDisplay.classList.add('shake');
                    setTimeout(() => selectedAmountDisplay.classList.remove('shake'), 500);
                }
            });

            // Supporters expand/collapse with pagination
            const toggleBtn = document.getElementById('toggleSupportersBtn');
            const toggleText = document.getElementById('toggleText');
            const toggleArrow = document.getElementById('toggleArrow');
            const pagination = document.getElementById('supportersPagination');
            const prevBtn = document.getElementById('prevPageBtn');
            const nextBtn = document.getElementById('nextPageBtn');
            const pageInfo = document.getElementById('paginationInfo');
            const supporters = document.querySelectorAll('.fund-detail-supporter');

            const totalSupporters = @Model.SupportersCount;
            const itemsPerPage = 5;
            let currentPage = 1;
            let isExpanded = false;

            function updatePagination() {
                const totalPages = Math.ceil(supporters.length / itemsPerPage);
                const startIndex = (currentPage - 1) * itemsPerPage;
                const endIndex = Math.min(startIndex + itemsPerPage, supporters.length);

                supporters.forEach((supporter, index) => {
                    if (isExpanded) {
                        if (index >= startIndex && index < endIndex) {
                            supporter.style.display = '';
                            supporter.style.animation = 'fadeSlideIn 0.3s ease forwards';
                            supporter.style.animationDelay = `${(index - startIndex) * 0.05}s`;
                        } else {
                            supporter.style.display = 'none';
                        }
                    } else {
                        // Show only first 3 when collapsed
                        supporter.style.display = index < 3 ? '' : 'none';
                    }
                });

                if (pageInfo) pageInfo.textContent = `Page ${currentPage} of ${totalPages}`;
                if (prevBtn) prevBtn.disabled = currentPage === 1;
                if (nextBtn) nextBtn.disabled = currentPage === totalPages || totalPages === 0;
            }

            if (toggleBtn) {
                toggleBtn.addEventListener('click', function() {
                    isExpanded = !isExpanded;

                    if (isExpanded) {
                        toggleText.textContent = 'Show less';
                        toggleArrow.textContent = '↑';
                        toggleArrow.style.transform = 'rotate(180deg)';
                        if (pagination && supporters.length > itemsPerPage) {
                            pagination.style.display = 'flex';
                        }
                        currentPage = 1;
                    } else {
                        toggleText.textContent = `See all ${totalSupporters} supporters`;
                        toggleArrow.textContent = '↓';
                        toggleArrow.style.transform = 'rotate(0deg)';
                        if (pagination) pagination.style.display = 'none';
                    }

                    updatePagination();
                });
            }

            if (prevBtn) {
                prevBtn.addEventListener('click', function() {
                    if (currentPage > 1) {
                        currentPage--;
                        updatePagination();
                    }
                });
            }

            if (nextBtn) {
                nextBtn.addEventListener('click', function() {
                    const totalPages = Math.ceil(supporters.length / itemsPerPage);
                    if (currentPage < totalPages) {
                        currentPage++;
                        updatePagination();
                    }
                });
            }

            // Updates modal functionality
            const openModalBtn = document.getElementById('openUpdateModal');
            const closeModalBtn = document.getElementById('closeUpdateModal');
            const cancelBtn = document.getElementById('cancelUpdate');
            const submitBtn = document.getElementById('submitUpdate');
            const updateModal = document.getElementById('updateModal');
            const modalBackdrop = document.getElementById('updateModalBackdrop');
            const updateTitle = document.getElementById('updateTitle');
            const updateContent = document.getElementById('updateContent');
            const updatesList = document.getElementById('updatesList');
            const emptyUpdates = document.getElementById('emptyUpdates');

            function openModal() {
                if (updateModal) {
                    updateModal.classList.add('active');
                    document.body.style.overflow = 'hidden';
                }
            }

            function closeModal() {
                if (updateModal) {
                    updateModal.classList.remove('active');
                    document.body.style.overflow = '';
                    if (updateTitle) updateTitle.value = '';
                    if (updateContent) updateContent.value = '';
                }
            }

            if (openModalBtn) openModalBtn.addEventListener('click', openModal);
            if (closeModalBtn) closeModalBtn.addEventListener('click', closeModal);
            if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
            if (modalBackdrop) modalBackdrop.addEventListener('click', closeModal);

            if (submitBtn) {
                submitBtn.addEventListener('click', async function() {
                    const title = updateTitle.value.trim();
                    const content = updateContent.value.trim();

                    if (!title || !content) {
                        alert('Please fill in both title and content');
                        return;
                    }

                    submitBtn.disabled = true;
                    submitBtn.textContent = 'Posting...';

                    try {
                        const response = await fetch('/Funds/PostUpdate', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `fundId=${fundId}&title=${encodeURIComponent(title)}&content=${encodeURIComponent(content)}`
                        });

                        const data = await response.json();

                        if (data.success) {
                            // Hide empty state if visible
                            if (emptyUpdates) emptyUpdates.style.display = 'none';

                            // Add the new update to the list
                            const updateHtml = `
                                <div class="update-item new-update">
                                    <div class="update-header">
                                        <h3 class="update-title">${data.update.title}</h3>
                                        <span class="update-date">${data.update.createdAt}</span>
                                    </div>
                                    <p class="update-content">${data.update.content}</p>
                                </div>
                            `;
                            updatesList.insertAdjacentHTML('afterbegin', updateHtml);

                            // Update the count
                            const countSpan = document.querySelector('.updates-count');
                            if (countSpan) {
                                const currentCount = parseInt(countSpan.textContent.match(/\d+/) || 0);
                                countSpan.textContent = `(${currentCount + 1})`;
                            }

                            closeModal();
                        } else {
                            alert(data.message || 'Failed to post update');
                        }
                    } catch (error) {
                        alert('An error occurred. Please try again.');
                    }

                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Post Update';
                });
            }

            // Milestones modal functionality
            const openMilestoneBtn = document.getElementById('openMilestoneModal');
            const closeMilestoneBtn = document.getElementById('closeMilestoneModal');
            const cancelMilestoneBtn = document.getElementById('cancelMilestone');
            const submitMilestoneBtn = document.getElementById('submitMilestone');
            const milestoneModal = document.getElementById('milestoneModal');
            const milestoneBackdrop = document.getElementById('milestoneModalBackdrop');
            const milestoneTitleInput = document.getElementById('milestoneTitle');
            const milestoneAmountInput = document.getElementById('milestoneAmount');
            const milestoneDescInput = document.getElementById('milestoneDescription');
            const milestonesList = document.getElementById('milestonesList');
            const emptyMilestones = document.getElementById('emptyMilestones');

            function openMilestoneModal() {
                if (milestoneModal) {
                    milestoneModal.classList.add('active');
                    document.body.style.overflow = 'hidden';
                }
            }

            function closeMilestoneModalFn() {
                if (milestoneModal) {
                    milestoneModal.classList.remove('active');
                    document.body.style.overflow = '';
                    if (milestoneTitleInput) milestoneTitleInput.value = '';
                    if (milestoneAmountInput) milestoneAmountInput.value = '';
                    if (milestoneDescInput) milestoneDescInput.value = '';
                }
            }

            if (openMilestoneBtn) openMilestoneBtn.addEventListener('click', openMilestoneModal);
            if (closeMilestoneBtn) closeMilestoneBtn.addEventListener('click', closeMilestoneModalFn);
            if (cancelMilestoneBtn) cancelMilestoneBtn.addEventListener('click', closeMilestoneModalFn);
            if (milestoneBackdrop) milestoneBackdrop.addEventListener('click', closeMilestoneModalFn);

            if (submitMilestoneBtn) {
                submitMilestoneBtn.addEventListener('click', async function() {
                    const mTitle = milestoneTitleInput.value.trim();
                    const mAmount = milestoneAmountInput.value.trim();
                    const mDesc = milestoneDescInput.value.trim();

                    if (!mTitle || !mAmount) {
                        alert('Please fill in the title and target amount');
                        return;
                    }

                    submitMilestoneBtn.disabled = true;
                    submitMilestoneBtn.textContent = 'Adding...';

                    try {
                        const response = await fetch('/Funds/AddMilestone', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `fundId=${fundId}&title=${encodeURIComponent(mTitle)}&targetAmount=${encodeURIComponent(mAmount)}&description=${encodeURIComponent(mDesc)}`
                        });

                        const data = await response.json();

                        if (data.success) {
                            if (emptyMilestones) emptyMilestones.style.display = 'none';

                            const raisedAmount = @Model.RaisedAmount;
                            const mProgress = Math.min(100, Math.round(raisedAmount / data.milestone.targetAmount * 100));
                            const reachedClass = data.milestone.isReached ? 'milestone-reached' : '';
                            const reachedBadge = data.milestone.isReached ? '<span class="milestone-badge">Reached!</span>' : '';
                            const descHtml = data.milestone.description ? `<p class="milestone-description">${data.milestone.description}</p>` : '';

                            const milestoneHtml = `
                                <div class="milestone-item new-milestone ${reachedClass}" data-milestone-id="${data.milestone.id}">
                                    <div class="milestone-header">
                                        <div class="milestone-title-row">
                                            <h3 class="milestone-title">${data.milestone.title}</h3>
                                            ${reachedBadge}
                                        </div>
                                        <div class="milestone-amount">\u20AC${Number(data.milestone.targetAmount).toLocaleString('en', {maximumFractionDigits: 0})}</div>
                                    </div>
                                    ${descHtml}
                                    <div class="milestone-progress-bar">
                                        <div class="milestone-progress-fill" style="--milestone-progress: ${mProgress}%;"></div>
                                    </div>
                                    <div class="milestone-footer">
                                        <span class="milestone-percent">${mProgress}% of milestone</span>
                                        <button class="milestone-delete-btn" data-milestone-id="${data.milestone.id}" title="Delete milestone">\u00D7</button>
                                    </div>
                                </div>
                            `;
                            milestonesList.insertAdjacentHTML('beforeend', milestoneHtml);

                            const mCountSpan = document.querySelector('.milestones-count');
                            if (mCountSpan) {
                                const curCount = parseInt(mCountSpan.textContent.match(/\d+/) || 0);
                                mCountSpan.textContent = `(${curCount + 1})`;
                            }

                            closeMilestoneModalFn();
                        } else {
                            alert(data.message || 'Failed to add milestone');
                        }
                    } catch (error) {
                        alert('An error occurred. Please try again.');
                    }

                    submitMilestoneBtn.disabled = false;
                    submitMilestoneBtn.textContent = 'Add Milestone';
                });
            }

            // Delete milestone handler (event delegation)
            if (milestonesList) {
                milestonesList.addEventListener('click', async function(e) {
                    const deleteBtn = e.target.closest('.milestone-delete-btn');
                    if (!deleteBtn) return;

                    if (!confirm('Are you sure you want to delete this milestone?')) return;

                    const msId = deleteBtn.dataset.milestoneId;

                    try {
                        const response = await fetch('/Funds/DeleteMilestone', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `milestoneId=${msId}`
                        });

                        const data = await response.json();

                        if (data.success) {
                            const item = deleteBtn.closest('.milestone-item');
                            item.style.opacity = '0';
                            item.style.transform = 'translateY(-10px)';
                            setTimeout(() => item.remove(), 300);

                            const mCountSpan = document.querySelector('.milestones-count');
                            if (mCountSpan) {
                                const curCount = parseInt(mCountSpan.textContent.match(/\d+/) || 0);
                                mCountSpan.textContent = `(${Math.max(0, curCount - 1)})`;
                            }
                        } else {
                            alert(data.message || 'Failed to delete milestone');
                        }
                    } catch (error) {
                        alert('An error occurred. Please try again.');
                    }
                });
            }


            // Extension modal functionality
            const extensionModal = document.getElementById('extensionModal');
            const extensionBackdrop = document.getElementById('extensionModalBackdrop');
            const openExtBtn = document.getElementById('openExtensionModal');
            const closeExtBtn = document.getElementById('closeExtensionModal');
            const cancelExtBtn = document.getElementById('cancelExtension');
            const submitExtBtn = document.getElementById('submitExtension');
            const extSlider = document.getElementById('extensionDaysSlider');
            const extInput = document.getElementById('extensionDaysInput');
            const extReason = document.getElementById('extensionReason');
            const extCharCount = document.getElementById('extensionCharCount');

            function openExtModal() {
                if (extensionModal) {
                    extensionModal.classList.add('active');
                    document.body.style.overflow = 'hidden';
                }
            }

            function closeExtModal() {
                if (extensionModal) {
                    extensionModal.classList.remove('active');
                    document.body.style.overflow = '';
                }
            }

            if (openExtBtn) openExtBtn.addEventListener('click', openExtModal);
            if (closeExtBtn) closeExtBtn.addEventListener('click', closeExtModal);
            if (cancelExtBtn) cancelExtBtn.addEventListener('click', closeExtModal);
            if (extensionBackdrop) extensionBackdrop.addEventListener('click', closeExtModal);

            if (extSlider && extInput) {
                extSlider.addEventListener('input', function() {
                    extInput.value = this.value;
                });
                extInput.addEventListener('input', function() {
                    var val = parseInt(this.value) || 1;
                    val = Math.max(1, Math.min(30, val));
                    this.value = val;
                    extSlider.value = val;
                });
            }

            if (extReason) {
                extReason.addEventListener('input', function() {
                    if (extCharCount) extCharCount.textContent = this.value.length;
                });
            }

            if (submitExtBtn) {
                submitExtBtn.addEventListener('click', async function() {
                    var days = parseInt(extInput ? extInput.value : 7);
                    var reason = extReason ? extReason.value.trim() : '';

                    if (!reason) {
                        alert('Please provide a reason for the extension');
                        return;
                    }

                    submitExtBtn.disabled = true;
                    submitExtBtn.textContent = 'Extending...';

                    try {
                        var response = await fetch('/Funds/RequestExtension', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: 'fundId=' + fundId + '&extensionDays=' + days + '&reason=' + encodeURIComponent(reason)
                        });

                        var data = await response.json();

                        if (data.success) {
                            closeExtModal();

                            // Update the days left stat
                            var statValues = document.querySelectorAll('.fund-detail-stat-value');
                            var statLabels = document.querySelectorAll('.fund-detail-stat-label');
                            if (statValues.length >= 3 && statLabels.length >= 3) {
                                statValues[2].textContent = data.daysLeft;
                                statLabels[2].textContent = 'days left';
                            }

                            // Hide extend button, show badge
                            if (openExtBtn) openExtBtn.closest('.extension-section').style.display = 'none';

                            var progressSection = document.querySelector('.fund-detail-progress-section');
                            if (progressSection) {
                                var badge = document.createElement('div');
                                badge.className = 'extension-badge';
                                badge.innerHTML = '<span class="extension-badge-icon">+' + data.extensionDays + '</span>'
                                    + '<span class="extension-badge-text">Extended by ' + data.extensionDays + ' days</span>';
                                progressSection.appendChild(badge);
                            }

                            alert(data.message);
                        } else {
                            alert(data.message || 'Failed to extend deadline');
                        }
                    } catch (error) {
                        alert('An error occurred. Please try again.');
                    }

                    submitExtBtn.disabled = false;
                    submitExtBtn.textContent = 'Extend Deadline';
                });
            }

            // === Comments Section ===
            const commentsList = document.getElementById('commentsList');
            const emptyComments = document.getElementById('emptyComments');
            const commentsCount = document.getElementById('commentsCount');
            const commentInput = document.getElementById('commentInput');
            const submitCommentBtn = document.getElementById('submitComment');
            const commentCharCount = document.getElementById('commentCharCount');

            function timeAgo(dateStr) {
                const now = new Date();
                const date = new Date(dateStr);
                const seconds = Math.floor((now - date) / 1000);
                if (seconds < 60) return 'just now';
                const minutes = Math.floor(seconds / 60);
                if (minutes < 60) return minutes + ' min ago';
                const hours = Math.floor(minutes / 60);
                if (hours < 24) return hours + (hours === 1 ? ' hour ago' : ' hours ago');
                const days = Math.floor(hours / 24);
                if (days < 7) return days + (days === 1 ? ' day ago' : ' days ago');
                return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
            }

            function renderComment(c) {
                const initial = (c.userName || '?')[0].toUpperCase();
                const deleteBtn = c.isOwner
                    ? `<button class="comment-delete-btn" data-comment-id="${c.id}" title="Delete comment">&times;</button>`
                    : '';
                return `<div class="comment-item" data-comment-id="${c.id}">
                    <div class="comment-avatar">${initial}</div>
                    <div class="comment-body">
                        <div class="comment-meta">
                            <span class="comment-username">${c.userName}</span>
                            <span class="comment-time">${timeAgo(c.createdAt)}</span>
                            ${deleteBtn}
                        </div>
                        <div class="comment-text">${c.content}</div>
                    </div>
                </div>`;
            }

            function loadComments() {
                fetch(`/Funds/GetComments?fundId=${fundId}`)
                    .then(r => r.json())
                    .then(data => {
                        commentsCount.textContent = `(${data.length})`;
                        if (data.length === 0) {
                            emptyComments.style.display = '';
                            return;
                        }
                        emptyComments.style.display = 'none';
                        const html = data.map(renderComment).join('');
                        commentsList.innerHTML = html + emptyComments.outerHTML;
                        emptyComments.style.display = 'none';
                        attachDeleteHandlers();
                    })
                    .catch(() => {});
            }

            function attachDeleteHandlers() {
                document.querySelectorAll('.comment-delete-btn').forEach(btn => {
                    btn.addEventListener('click', function() {
                        const id = this.dataset.commentId;
                        if (!confirm('Delete this comment?')) return;
                        fetch('/Funds/DeleteComment', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ commentId: parseInt(id) })
                        })
                        .then(r => r.json())
                        .then(data => {
                            if (data.success) loadComments();
                        });
                    });
                });
            }

            if (commentInput) {
                commentInput.addEventListener('input', function() {
                    const len = this.value.trim().length;
                    commentCharCount.textContent = `${this.value.length}/1000`;
                    submitCommentBtn.disabled = len === 0;
                });
            }

            if (submitCommentBtn) {
                submitCommentBtn.addEventListener('click', function() {
                    const content = commentInput.value.trim();
                    if (!content) return;
                    submitCommentBtn.disabled = true;
                    submitCommentBtn.textContent = 'Posting...';
                    fetch('/Funds/AddComment', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ fundId: fundId, content: content })
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            commentInput.value = '';
                            commentCharCount.textContent = '0/1000';
                            loadComments();
                        }
                    })
                    .finally(() => {
                        submitCommentBtn.disabled = false;
                        submitCommentBtn.textContent = 'Post Comment';
                    });
                });
            }

            loadComments();

            // Refund donation (creator only)
            window.refundDonation = async function(donationId, btnElement) {
                if (!confirm('Are you sure you want to refund this donation?')) return;

                btnElement.disabled = true;
                btnElement.style.opacity = '0.5';

                try {
                    const response = await fetch('/Funds/RefundDonation', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: `donationId=${donationId}`
                    });
                    const data = await response.json();

                    if (data.success) {
                        const supporterEl = btnElement.closest('.fund-detail-supporter');
                        const amount = parseFloat(supporterEl.dataset.donationAmount) || 0;

                        // Animate removal
                        supporterEl.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                        supporterEl.style.opacity = '0';
                        supporterEl.style.transform = 'translateX(20px)';
                        setTimeout(() => supporterEl.remove(), 300);

                        // Update raised amount display
                        const raisedEl = document.querySelector('.fund-detail-raised');
                        if (raisedEl) {
                            const currentRaised = parseInt(raisedEl.textContent.replace(/[^0-9]/g, '')) || 0;
                            const newRaised = Math.max(0, currentRaised - amount);
                            raisedEl.textContent = '\u20AC' + newRaised.toLocaleString('en-US', { maximumFractionDigits: 0 });
                        }
                    } else {
                        alert(data.message || 'Refund failed');
                        btnElement.disabled = false;
                        btnElement.style.opacity = '1';
                    }
                } catch (e) {
                    alert('An error occurred while processing the refund');
                    btnElement.disabled = false;
                    btnElement.style.opacity = '1';
                }
            };

        });
    </script>

    <style>
        .supporters-expand-section {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 12px;
        }

        .fund-detail-see-all {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 16px;
            background: rgba(70, 230, 164, 0.1);
            border: 1px solid rgba(70, 230, 164, 0.3);
            border-radius: 10px;
            color: #46e6a4;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .fund-detail-see-all:hover {
            background: rgba(70, 230, 164, 0.2);
            border-color: rgba(70, 230, 164, 0.5);
        }

        .toggle-arrow {
            transition: transform 0.3s ease;
        }

        .supporters-pagination {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .pagination-btn {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--text-muted);
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .pagination-btn:hover:not(:disabled) {
            background: rgba(70, 230, 164, 0.15);
            border-color: rgba(70, 230, 164, 0.4);
            color: #46e6a4;
        }

        .pagination-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

        .pagination-info {
            font-size: 12px;
            color: var(--text-muted);
        }

        .fund-detail-supporter {
            opacity: 0;
            animation: fadeSlideIn 0.3s ease forwards;
        }

        @@keyframes fadeSlideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }


            // Team modal functionality
            const openTeamBtn = document.getElementById('openTeamModal');
            const closeTeamBtn = document.getElementById('closeTeamModal');
            const closeTeamFooterBtn = document.getElementById('closeTeamBtn');
            const teamModal = document.getElementById('teamModal');
            const teamBackdrop = document.getElementById('teamModalBackdrop');
            const inviteBtn = document.getElementById('inviteCollab');
            const collabEmail = document.getElementById('collabEmail');
            const collabList = document.getElementById('collabList');
            const collabEmpty = document.getElementById('collabEmpty');

            function openTeamModal() {
                if (teamModal) {
                    teamModal.classList.add('active');
                    document.body.style.overflow = 'hidden';
                }
            }

            function closeTeamModal() {
                if (teamModal) {
                    teamModal.classList.remove('active');
                    document.body.style.overflow = '';
                }
            }

            if (openTeamBtn) openTeamBtn.addEventListener('click', openTeamModal);
            if (closeTeamBtn) closeTeamBtn.addEventListener('click', closeTeamModal);
            if (closeTeamFooterBtn) closeTeamFooterBtn.addEventListener('click', closeTeamModal);
            if (teamBackdrop) teamBackdrop.addEventListener('click', closeTeamModal);

            if (inviteBtn) {
                inviteBtn.addEventListener('click', async function() {
                    const email = collabEmail.value.trim();
                    if (!email) {
                        alert('Please enter an email address');
                        return;
                    }

                    inviteBtn.disabled = true;
                    inviteBtn.textContent = 'Inviting...';

                    try {
                        const response = await fetch('/Funds/AddCollaborator', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `fundId=${fundId}&email=${encodeURIComponent(email)}`
                        });

                        const data = await response.json();

                        if (data.success) {
                            if (collabEmpty) collabEmpty.style.display = 'none';

                            const itemHtml = `
                                <div class="collab-item" data-id="${data.collaborator.id}">
                                    <div class="collab-item-info">
                                        <div class="collaborator-avatar"></div>
                                        <span>${data.collaborator.email}</span>
                                        <span class="collab-role">${data.collaborator.role}</span>
                                    </div>
                                    <button class="collab-remove-btn" data-id="${data.collaborator.id}">×</button>
                                </div>
                            `;
                            collabList.insertAdjacentHTML('beforeend', itemHtml);

                            // Add collaborator chip to the page
                            const chipsContainer = document.querySelector('.collaborators-list');
                            if (chipsContainer) {
                                const chipHtml = '<div class="collaborator-chip">'
                                    + '<div class="collaborator-avatar"></div>'
                                    + '<span>@@' + data.collaborator.email.split('@@')[0] + '</span>'
                                    + '</div>';
                                chipsContainer.insertAdjacentHTML('beforeend', chipHtml);
                            } else {
                                // Create the collaborators section if it doesn't exist
                                const creatorDiv = document.querySelector('.fund-detail-creator');
                                if (creatorDiv) {
                                    const sectionHtml = '<div class="fund-collaborators">'
                                        + '<span class="collaborators-label">Team:</span>'
                                        + '<div class="collaborators-list">'
                                        + '<div class="collaborator-chip">'
                                        + '<div class="collaborator-avatar"></div>'
                                        + '<span>@@' + data.collaborator.email.split('@@')[0] + '</span>'
                                        + '</div></div></div>';
                                    creatorDiv.insertAdjacentHTML('afterend', sectionHtml);
                                }
                            }

                            collabEmail.value = '';
                        } else {
                            alert(data.message || 'Failed to add collaborator');
                        }
                    } catch (error) {
                        alert('An error occurred. Please try again.');
                    }

                    inviteBtn.disabled = false;
                    inviteBtn.textContent = 'Invite';
                });
            }

            // Remove collaborator (event delegation)
            if (collabList) {
                collabList.addEventListener('click', async function(e) {
                    const removeBtn = e.target.closest('.collab-remove-btn');
                    if (!removeBtn) return;

                    const collabId = removeBtn.dataset.id;
                    if (!confirm('Remove this collaborator?')) return;

                    try {
                        const response = await fetch('/Funds/RemoveCollaborator', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: `collaboratorId=${collabId}`
                        });

                        const data = await response.json();

                        if (data.success) {
                            const item = collabList.querySelector(`.collab-item[data-id="${collabId}"]`);
                            if (item) item.remove();

                            if (!collabList.querySelector('.collab-item')) {
                                if (collabEmpty) {
                                    collabEmpty.style.display = '';
                                } else {
                                    collabList.innerHTML = '<div class="collab-empty" id="collabEmpty"><p>No collaborators yet</p></div>';
                                }
                            }
                        } else {
                            alert(data.message || 'Failed to remove collaborator');
                        }
                    } catch (error) {
                        alert('An error occurred. Please try again.');
                    }
                });
            }
