@model KryskataFund.Models.Fund
@{
    Layout = null;
    var progressPercent = Model.ProgressPercent;
    var detailsUrl = $"/Funds/Details/{Model.Id}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.Title - KryskataFund</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0a0b10;
            color: #e4e4e7;
            padding: 16px;
            min-height: 100vh;
        }

        .embed-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            overflow: hidden;
        }

        .embed-header {
            display: flex;
            gap: 12px;
            padding: 14px;
        }

        .embed-image {
            width: 64px;
            height: 64px;
            border-radius: 10px;
            object-fit: cover;
            flex-shrink: 0;
            background: rgba(255, 255, 255, 0.05);
        }

        .embed-info {
            flex: 1;
            min-width: 0;
        }

        .embed-title {
            font-size: 14px;
            font-weight: 600;
            color: #f4f4f5;
            margin-bottom: 6px;
            line-height: 1.3;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .embed-category {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 8px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 6px;
            font-size: 11px;
            color: rgba(255, 255, 255, 0.6);
        }

        .embed-category-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }

        .embed-body {
            padding: 0 14px 14px;
        }

        .embed-progress-bar {
            height: 6px;
            background: rgba(255, 255, 255, 0.08);
            border-radius: 3px;
            overflow: hidden;
            margin-bottom: 10px;
        }

        .embed-progress-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 0.6s ease;
        }

        .embed-amounts {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 12px;
        }

        .embed-raised {
            font-size: 16px;
            font-weight: 700;
        }

        .embed-goal {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.5);
        }

        .embed-stats {
            display: flex;
            gap: 16px;
            margin-bottom: 14px;
        }

        .embed-stat {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.5);
        }

        .embed-stat strong {
            color: #e4e4e7;
            font-weight: 600;
        }

        .embed-btn {
            display: block;
            width: 100%;
            padding: 10px;
            border: none;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 600;
            color: #050509;
            text-align: center;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .embed-btn:hover {
            transform: translateY(-1px);
            filter: brightness(1.1);
        }
    </style>
</head>
<body>
    <div class="embed-card">
        <div class="embed-header">
            @if (Model.ImageUrl != null)
            {
                <img src="@Model.ImageUrl" alt="@Model.Title" class="embed-image">
            }
            <div class="embed-info">
                <div class="embed-title">@Model.Title</div>
                <span class="embed-category">
                    <span class="embed-category-dot" style="background: @Model.CategoryColor; box-shadow: 0 0 6px @Model.CategoryColor;"></span>
                    @Model.Category
                </span>
            </div>
        </div>
        <div class="embed-body">
            <div class="embed-progress-bar">
                <div class="embed-progress-fill" style="width: @Math.Min(100, progressPercent)%; background: linear-gradient(90deg, @Model.CategoryColor, @(Model.CategoryColor)aa);"></div>
            </div>
            <div class="embed-amounts">
                <span class="embed-raised" style="color: @Model.CategoryColor;">@("\u20AC")@Model.RaisedAmount.ToString("N0")</span>
                <span class="embed-goal">of @("\u20AC")@Model.GoalAmount.ToString("N0") goal</span>
            </div>
            <div class="embed-stats">
                <span class="embed-stat"><strong>@Model.SupportersCount</strong> supporters</span>
                <span class="embed-stat"><strong>@(Model.DaysLeft == 0 ? "Ended" : Model.DaysLeft.ToString())</strong> @(Model.DaysLeft == 0 ? "" : "days left")</span>
            </div>
            <a href="@detailsUrl" target="_blank" rel="noopener" class="embed-btn" style="background: linear-gradient(135deg, @Model.CategoryColor, @(Model.CategoryColor)cc);">
                Support this campaign
            </a>
        </div>
    </div>
</body>
</html>
