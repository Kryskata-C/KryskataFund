@{
    ViewData["Title"] = "Conversation";
    var messages = ViewBag.Messages as List<KryskataFund.Models.Message> ?? new List<KryskataFund.Models.Message>();
    var currentUserId = (int)ViewBag.CurrentUserId;
    var otherUserId = (int)ViewBag.OtherUserId;
    var otherUserEmail = (string)ViewBag.OtherUserEmail;
    var otherInitial = !string.IsNullOrEmpty(otherUserEmail) ? otherUserEmail[0].ToString().ToUpper() : "?";
}

<style>
    .chat-page {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 20px;
        display: flex;
        flex-direction: column;
        height: calc(100vh - 80px);
    }

    .chat-header {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 20px 0;
        border-bottom: 1px solid #222437;
        flex-shrink: 0;
    }

    .chat-back {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 12px;
        background: #141522;
        border: 1px solid #222437;
        color: #a0a3c4;
        text-decoration: none;
        font-size: 1.1rem;
        transition: all 0.2s ease;
        flex-shrink: 0;
    }

    .chat-back:hover {
        background: #1a1b2e;
        border-color: rgba(70, 230, 164, 0.3);
        color: #46e6a4;
    }

    .chat-header-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg, #46e6a4, #38bdf8);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
        color: #050509;
        flex-shrink: 0;
    }

    .chat-header-info {
        flex: 1;
        min-width: 0;
    }

    .chat-header-name {
        font-size: 0.95rem;
        font-weight: 600;
        color: #f7f7ff;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .chat-header-sub {
        font-size: 0.75rem;
        color: #6d6f8c;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 24px 0;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .chat-messages::-webkit-scrollbar {
        width: 6px;
    }

    .chat-messages::-webkit-scrollbar-track {
        background: transparent;
    }

    .chat-messages::-webkit-scrollbar-thumb {
        background: #222437;
        border-radius: 999px;
    }

    .chat-bubble-wrap {
        display: flex;
        max-width: 75%;
    }

    .chat-bubble-wrap.sent {
        align-self: flex-end;
    }

    .chat-bubble-wrap.received {
        align-self: flex-start;
    }

    .chat-bubble {
        padding: 10px 16px;
        border-radius: 18px;
        font-size: 0.88rem;
        line-height: 1.5;
        word-break: break-word;
        position: relative;
    }

    .chat-bubble-wrap.sent .chat-bubble {
        background: linear-gradient(135deg, #46e6a4, #38d99a);
        color: #050509;
        border-bottom-right-radius: 6px;
    }

    .chat-bubble-wrap.received .chat-bubble {
        background: #141522;
        color: #f7f7ff;
        border: 1px solid #222437;
        border-bottom-left-radius: 6px;
    }

    .chat-bubble-time {
        font-size: 0.68rem;
        margin-top: 4px;
        opacity: 0.6;
    }

    .chat-bubble-wrap.sent .chat-bubble-time {
        text-align: right;
        color: #050509;
    }

    .chat-bubble-wrap.received .chat-bubble-time {
        color: #6d6f8c;
    }

    .chat-bubble-actions {
        display: none;
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        gap: 4px;
    }

    .chat-bubble-wrap.sent .chat-bubble-actions {
        left: -32px;
    }

    .chat-bubble-wrap.sent:hover .chat-bubble-actions {
        display: flex;
    }

    .chat-delete-btn {
        width: 24px;
        height: 24px;
        border-radius: 8px;
        border: none;
        background: rgba(239, 68, 68, 0.15);
        color: #ef4444;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        transition: all 0.15s ease;
    }

    .chat-delete-btn:hover {
        background: rgba(239, 68, 68, 0.3);
    }

    .chat-date-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 16px 0;
    }

    .chat-date-divider::before,
    .chat-date-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #222437;
    }

    .chat-date-divider span {
        font-size: 0.72rem;
        color: #6d6f8c;
        font-weight: 500;
    }

    .chat-input-wrap {
        padding: 16px 0 24px;
        border-top: 1px solid #222437;
        flex-shrink: 0;
    }

    .chat-input-form {
        display: flex;
        gap: 10px;
        align-items: flex-end;
    }

    .chat-input {
        flex: 1;
        padding: 12px 18px;
        border-radius: 18px;
        border: 1px solid #222437;
        background: #0f1017;
        color: #f7f7ff;
        font-size: 0.88rem;
        outline: none;
        resize: none;
        min-height: 44px;
        max-height: 120px;
        font-family: inherit;
        line-height: 1.4;
        transition: border-color 0.2s ease;
    }

    .chat-input::placeholder {
        color: #6d6f8c;
    }

    .chat-input:focus {
        border-color: rgba(70, 230, 164, 0.4);
        box-shadow: 0 0 0 3px rgba(70, 230, 164, 0.08);
    }

    .chat-send-btn {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        border: none;
        background: #46e6a4;
        color: #050509;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: all 0.2s ease;
    }

    .chat-send-btn:hover {
        background: #5aebb3;
        transform: scale(1.05);
    }

    .chat-send-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
        transform: none;
    }

    .chat-send-btn svg {
        width: 20px;
        height: 20px;
    }

    .chat-empty {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 12px;
        color: #6d6f8c;
        font-size: 0.88rem;
    }

    .chat-empty-icon {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #141522;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .chat-empty-icon svg {
        width: 24px;
        height: 24px;
        opacity: 0.4;
        color: #a0a3c4;
    }

    .chat-char-count {
        font-size: 0.7rem;
        color: #6d6f8c;
        text-align: right;
        margin-top: 4px;
        transition: color 0.2s;
    }

    .chat-char-count.near-limit {
        color: #f97316;
    }

    .chat-char-count.at-limit {
        color: #ef4444;
    }
</style>

<div class="chat-page">
    <div class="chat-header">
        <a asp-action="Inbox" class="chat-back">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
        </a>
        <div class="chat-header-avatar">@otherInitial</div>
        <div class="chat-header-info">
            <div class="chat-header-name">@otherUserEmail</div>
            <div class="chat-header-sub">Direct message</div>
        </div>
    </div>

    <div class="chat-messages" id="chatMessages">
        @if (!messages.Any())
        {
            <div class="chat-empty" id="chatEmpty">
                <div class="chat-empty-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                </div>
                <span>Start the conversation</span>
            </div>
        }
        else
        {
            string lastDate = "";
            foreach (var msg in messages)
            {
                var msgDate = msg.SentAt.ToString("MMM d, yyyy");
                if (msgDate != lastDate)
                {
                    lastDate = msgDate;
                    <div class="chat-date-divider"><span>@msgDate</span></div>
                }
                var isSent = msg.SenderId == currentUserId;
                <div class="chat-bubble-wrap @(isSent ? "sent" : "received")" data-msg-id="@msg.Id">
                    <div class="chat-bubble">
                        @if (isSent)
                        {
                            <div class="chat-bubble-actions">
                                <button class="chat-delete-btn" onclick="deleteMessage(@msg.Id, this)" title="Delete">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                                        <path d="M18 6L6 18M6 6l12 12"/>
                                    </svg>
                                </button>
                            </div>
                        }
                        <div>@msg.Content</div>
                        <div class="chat-bubble-time">@msg.SentAt.ToString("h:mm tt")</div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="chat-input-wrap">
        <div class="chat-input-form">
            <textarea class="chat-input" id="chatInput" placeholder="Type a message..." rows="1" maxlength="1000"></textarea>
            <button class="chat-send-btn" id="chatSendBtn" disabled title="Send">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="22" y1="2" x2="11" y2="13"/>
                    <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                </svg>
            </button>
        </div>
        <div class="chat-char-count" id="charCount"></div>
    </div>
</div>

<script>
(function() {
    var chatMessages = document.getElementById('chatMessages');
    var chatInput = document.getElementById('chatInput');
    var chatSendBtn = document.getElementById('chatSendBtn');
    var charCount = document.getElementById('charCount');
    var receiverId = @otherUserId;
    var sending = false;

    // Auto-scroll to bottom
    chatMessages.scrollTop = chatMessages.scrollHeight;

    // Auto-resize textarea
    chatInput.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';

        var len = this.value.length;
        chatSendBtn.disabled = len === 0 || len > 1000;

        if (len > 900) {
            charCount.textContent = len + '/1000';
            charCount.className = 'chat-char-count' + (len > 980 ? ' at-limit' : ' near-limit');
        } else {
            charCount.textContent = '';
            charCount.className = 'chat-char-count';
        }
    });

    // Send on Enter (Shift+Enter for new line)
    chatInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    chatSendBtn.addEventListener('click', sendMessage);

    function sendMessage() {
        var content = chatInput.value.trim();
        if (!content || content.length > 1000 || sending) return;

        sending = true;
        chatSendBtn.disabled = true;

        fetch('/Messages/Send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'receiverId=' + receiverId + '&content=' + encodeURIComponent(content)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                // Remove empty state if present
                var emptyEl = document.getElementById('chatEmpty');
                if (emptyEl) emptyEl.remove();

                // Add message bubble
                var wrap = document.createElement('div');
                wrap.className = 'chat-bubble-wrap sent';
                wrap.setAttribute('data-msg-id', data.message.Id);
                wrap.innerHTML =
                    '<div class="chat-bubble">' +
                        '<div class="chat-bubble-actions">' +
                            '<button class="chat-delete-btn" onclick="deleteMessage(' + data.message.Id + ', this)" title="Delete">' +
                                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">' +
                                    '<path d="M18 6L6 18M6 6l12 12"/>' +
                                '</svg>' +
                            '</button>' +
                        '</div>' +
                        '<div>' + escapeHtml(data.message.Content) + '</div>' +
                        '<div class="chat-bubble-time">' + data.message.SentAt + '</div>' +
                    '</div>';
                chatMessages.appendChild(wrap);
                chatMessages.scrollTop = chatMessages.scrollHeight;

                chatInput.value = '';
                chatInput.style.height = 'auto';
                charCount.textContent = '';
                charCount.className = 'chat-char-count';
            }
        })
        .catch(function() {})
        .finally(function() {
            sending = false;
            chatSendBtn.disabled = chatInput.value.trim().length === 0;
            chatInput.focus();
        });
    }

    function escapeHtml(text) {
        var div = document.createElement('div');
        div.appendChild(document.createTextNode(text));
        return div.innerHTML;
    }

    // Make deleteMessage global
    window.deleteMessage = function(id, btn) {
        if (!confirm('Delete this message?')) return;
        fetch('/Messages/Delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id=' + id
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                var bubble = btn.closest('.chat-bubble-wrap');
                if (bubble) bubble.remove();
            }
        })
        .catch(function() {});
    };
})();
</script>
